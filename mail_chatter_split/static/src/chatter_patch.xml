<?xml version="1.0" encoding="UTF-8" ?>
<templates xml:space="preserve">
    <t t-name="mail.Chatter" t-inherit="mail.Chatter" t-inherit-mode="extension">
        <xpath expr="//div[hasclass('o-mail-Chatter-content')]" position="before">
            <div
                t-if="props.hasMessageList and state.thread"
                class="o-mail-ChatterSplit-tabs d-flex px-3 py-2"
            >
                <div
                    class="btn-group btn-group-sm"
                    role="group"
                    aria-label="Chatter view toggle"
                >
                    <button
                        type="button"
                        class="btn"
                        t-att-class="{
                                'btn-primary': isViewAll,
                                'btn-outline-secondary': !isViewAll
                            }"
                        t-on-click="() => this.setChatterView('all')"
                    >
                        <i class="fa fa-list-alt" />
                        <span class="d-none d-md-inline ms-1">All</span>
                    </button>
                    <button
                        type="button"
                        class="btn"
                        t-att-class="{
                                'btn-primary': isViewMessages,
                                'btn-outline-secondary': !isViewMessages
                            }"
                        t-on-click="() => this.setChatterView('messages')"
                    >
                        <i class="fa fa-comments" />
                        <span class="d-none d-md-inline ms-1">Messages</span>
                    </button>
                    <button
                        type="button"
                        class="btn"
                        t-att-class="{
                                'btn-primary': isViewLogs,
                                'btn-outline-secondary': !isViewLogs
                            }"
                        t-on-click="() => this.setChatterView('logs')"
                    >
                        <i class="fa fa-history" />
                        <span class="d-none d-md-inline ms-1">Logs</span>
                    </button>
                    <button
                        type="button"
                        class="btn"
                        t-att-class="{
                                'btn-primary': isViewActivities,
                                'btn-outline-secondary': !isViewActivities
                            }"
                        t-on-click="() => this.setChatterView('activities')"
                    >
                        <i class="fa fa-clock-o" />
                        <span class="d-none d-md-inline ms-1">Activities</span>
                    </button>
                </div>
            </div>
        </xpath>
    </t>
</templates>
