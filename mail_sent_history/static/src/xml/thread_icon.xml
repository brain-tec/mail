<?xml version="1.0" encoding="utf-8" ?>
<odoo>
    <t t-inherit="mail.ThreadIcon" t-inherit-mode="extension">
        <xpath expr="//div[contains(@class, 'o-mail-ThreadIcon')]" position="inside">
            <div
                t-if="props.thread.id === 'sent_history'"
                class="fa fa-fw fa-paper-plane"
                title="Sent History"
            />
        </xpath>
    </t>
</odoo>
